<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <!-- User Info Header -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/avatarCard"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="50dp"
            app:cardElevation="0dp"
            app:strokeWidth="2dp"
            app:strokeColor="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imgProfile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_profile" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Dr. Alex Morgan"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/avatarCard" />

        <TextView
            android:id="@+id/tvEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="alex.morgan@research.edu"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvName" />

        <!-- First Group -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/group1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/line"
            app:cardBackgroundColor="@color/white"
            app:layout_constraintTop_toBottomOf="@id/tvEmail">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditProfile"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical|start"
                    android:paddingHorizontal="20dp"
                    android:text="Edit Profile"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    app:icon="@android:drawable/ic_menu_edit"
                    app:iconPadding="16dp"
                    app:iconSize="24dp"
                    app:iconTint="@color/accent" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="@color/line" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnChangePassword"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical|start"
                    android:paddingHorizontal="20dp"
                    android:text="Change Password"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    app:icon="@android:drawable/ic_lock_idle_lock"
                    app:iconPadding="16dp"
                    app:iconSize="24dp"
                    app:iconTint="@color/accent" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="@color/line" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSettings"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical|start"
                    android:paddingHorizontal="20dp"
                    android:text="Settings"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    app:icon="@android:drawable/ic_menu_manage"
                    app:iconPadding="16dp"
                    app:iconSize="24dp"
                    app:iconTint="@color/accent" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Second Group -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/group2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/line"
            app:cardBackgroundColor="@color/white"
            app:layout_constraintTop_toBottomOf="@id/group1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLibrary"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical|start"
                    android:paddingHorizontal="20dp"
                    android:text="Educational Hub"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    app:icon="@android:drawable/ic_menu_agenda"
                    app:iconPadding="16dp"
                    app:iconSize="24dp"
                    app:iconTint="@color/accent" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="@color/line" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFaq"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical|start"
                    android:paddingHorizontal="20dp"
                    android:text="Help &amp; Support"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    app:icon="@android:drawable/ic_menu_help"
                    app:iconPadding="16dp"
                    app:iconSize="24dp"
                    app:iconTint="@color/accent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSpecialists"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical|start"
                    android:paddingHorizontal="20dp"
                    android:text="Find Specialists"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    app:icon="@android:drawable/ic_menu_myplaces"
                    app:iconPadding="16dp"
                    app:iconSize="24dp"
                    app:iconTint="@color/accent" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="@color/line" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReminders"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical|start"
                    android:paddingHorizontal="20dp"
                    android:text="Treatment Reminders"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    app:icon="@android:drawable/ic_popup_reminder"
                    app:iconPadding="16dp"
                    app:iconSize="24dp"
                    app:iconTint="@color/accent" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="@color/line" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTerms"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical|start"
                    android:paddingHorizontal="20dp"
                    android:text="Privacy Policy"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    app:icon="@android:drawable/ic_menu_info_details"
                    app:iconPadding="16dp"
                    app:iconSize="24dp"
                    app:iconTint="@color/accent" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="@color/line" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogout"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical|start"
                    android:paddingHorizontal="20dp"
                    android:text="Logout"
                    android:textAllCaps="false"
                    android:textColor="@color/danger"
                    android:textSize="16sp"
                    app:icon="@android:drawable/ic_lock_power_off"
                    app:iconPadding="16dp"
                    app:iconSize="24dp"
                    app:iconTint="@color/danger" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Bottom spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="40dp"
            app:layout_constraintTop_toBottomOf="@id/group2" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>