<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Eye Care Tips"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"/>

        <TextView
            android:layout_marginTop="20dp"
            android:text="• Follow the 20-20-20 rule for screen use."
            android:textSize="14sp"
            android:textColor="@color/text_dark"/>

        <TextView
            android:layout_marginTop="12dp"
            android:text="• Avoid touching or rubbing your eyes."
            android:textSize="14sp"
            android:textColor="@color/text_dark"/>

        <TextView
            android:layout_marginTop="12dp"
            android:text="• Maintain proper eye hygiene."
            android:textSize="14sp"
            android:textColor="@color/text_dark"/>

        <TextView
            android:layout_marginTop="12dp"
            android:text="• Wear protective eyewear when needed."
            android:textSize="14sp"
            android:textColor="@color/text_dark"/>

        <TextView
            android:layout_marginTop="12dp"
            android:text="• Visit an ophthalmologist for regular checkups."
            android:textSize="14sp"
            android:textColor="@color/text_dark"/>

        <TextView
            android:layout_marginTop="24dp"
            android:text="Reminder: Early detection prevents vision loss."
            android:textStyle="bold"
            android:textColor="@color/primary"/>
    </LinearLayout>
</ScrollView>