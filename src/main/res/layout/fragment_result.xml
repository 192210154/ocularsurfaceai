<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"   
    xmlns:app="http://schemas.android.com/apk/res-auto"   
    xmlns:tools="http://schemas.android.com/tools"   
    android:layout_width="match_parent"   
    android:layout_height="match_parent"   
    android:background="@color/bg"   
    android:fillViewport="true">    <androidx.constraintlayout.widget.ConstraintLayout       
    android:layout_width="match_parent"       
    android:layout_height="wrap_content"       
    android:paddingBottom="40dp">

        <com.google.android.material.card.MaterialCardView           
    android:id="@+id/cardResult"           
    android:layout_width="match_parent"           
    android:layout_height="wrap_content"           
    android:layout_marginHorizontal="20dp"           
    android:layout_marginTop="24dp"            app:cardCornerRadius="28dp"            app:cardElevation="0dp"            app:strokeWidth="1dp"            app:strokeColor="@color/line"            app:cardBackgroundColor="@color/white"            app:layout_constraintTop_toTopOf="parent">
            <androidx.constraintlayout.widget.ConstraintLayout               
    android:layout_width="match_parent"               
    android:layout_height="wrap_content"               
    android:paddingBottom="24dp">                <com.google.android.material.card.MaterialCardView                   
    android:id="@+id/cardImage"                   
    android:layout_width="match_parent"                   
    android:layout_height="240dp"                   
    android:layout_margin="12dp"                    app:cardCornerRadius="22dp"                    app:cardElevation="0dp"                    app:layout_constraintTop_toTopOf="parent">                    <ImageView                       
    android:id="@+id/imgResult"                       
    android:layout_width="match_parent"                       
    android:layout_height="match_parent"                       
    android:scaleType="centerCrop"                       
    android:src="@drawable/ic_launcher_background"                       
    android:transitionName="eye_image" />                    <TextView                       
    android:id="@+id/tvDate"                       
    android:layout_width="wrap_content"                       
    android:layout_height="wrap_content"                       
    android:layout_gravity="top|end"                       
    android:layout_margin="16dp"                       
    android:background="@drawable/bg_pill_dark"                       
    android:paddingHorizontal="12dp"                       
    android:paddingVertical="6dp"                       
    android:text="Today"                       
    android:textColor="@color/white"                       
    android:textSize="11sp"                       
    android:textStyle="bold" />                </com.google.android.material.card.MaterialCardView>                <TextView                   
    android:id="@+id/tvDetectedHeader"                   
    android:layout_width="wrap_content"                   
    android:layout_height="wrap_content"                   
    android:layout_marginStart="20dp"                   
    android:layout_marginTop="20dp"                   
    android:text="DETECTED CONDITION"                   
    android:textColor="@color/text_secondary"                   
    android:textSize="11sp"                   
    android:textStyle="bold"                   
    android:letterSpacing="0.05"                    app:layout_constraintStart_toStartOf="parent"                    app:layout_constraintTop_toBottomOf="@id/cardImage" />                <TextView                   
    android:id="@+id/tvSeverity"                   
    android:layout_width="wrap_content"                   
    android:layout_height="wrap_content"                   
    android:layout_marginEnd="20dp"                   
    android:background="@drawable/bg_input_modern"                   
    android:paddingHorizontal="14dp"                   
    android:paddingVertical="6dp"                   
    android:text="Mild"                   
    android:textColor="@color/success"                   
    android:textSize="12sp"                   
    android:textStyle="bold"                    app:layout_constraintBottom_toBottomOf="@id/tvLabel"                    app:layout_constraintEnd_toEndOf="parent"                    app:layout_constraintTop_toTopOf="@id/tvLabel" />                <TextView                   
    android:id="@+id/tvLabel"                   
    android:layout_width="0dp"                   
    android:layout_height="wrap_content"                   
    android:layout_marginTop="6dp"                   
    android:layout_marginEnd="8dp"                   
    android:text="Normal"                   
    android:textColor="@color/text_primary"                   
    android:textSize="26sp"                   
    android:textStyle="bold"                   
    android:fontFamily="@font/outfit"                    app:layout_constraintEnd_toStartOf="@id/tvSeverity"                    app:layout_constraintStart_toStartOf="@id/tvDetectedHeader"                    app:layout_constraintTop_toBottomOf="@id/tvDetectedHeader" />                <com.google.android.material.progressindicator.LinearProgressIndicator                   
    android:id="@+id/progress"                   
    android:layout_width="0dp"                   
    android:layout_height="wrap_content"                   
    android:layout_marginTop="20dp"                   
    android:layout_marginHorizontal="20dp"                   
    android:progress="100"                    app:indicatorColor="@color/success"                    app:trackColor="@color/primary_soft"                    app:trackCornerRadius="4dp"                    app:trackThickness="8dp"                    app:layout_constraintEnd_toEndOf="parent"                    app:layout_constraintStart_toStartOf="parent"                    app:layout_constraintTop_toBottomOf="@id/tvLabel" />                <com.airbnb.lottie.LottieAnimationView                   
    android:id="@+id/lottieSuccess"                   
    android:layout_width="48dp"                   
    android:layout_height="48dp"                   
    android:layout_marginTop="8dp"                    app:lottie_autoPlay="true"                    app:lottie_loop="false"                    app:lottie_rawRes="@raw/success_check"                    app:layout_constraintEnd_toEndOf="@id/progress"                    app:layout_constraintTop_toBottomOf="@id/progress" />                <TextView                   
    android:id="@+id/tvConfidence"                   
    android:layout_width="wrap_content"                   
    android:layout_height="wrap_content"                   
    android:text="Confidence: 98%"                   
    android:textColor="@color/text_muted"                   
    android:textSize="12sp"                    app:layout_constraintBottom_toBottomOf="@id/lottieSuccess"                    app:layout_constraintEnd_toStartOf="@id/lottieSuccess"                    app:layout_constraintTop_toTopOf="@id/lottieSuccess" />            </androidx.constraintlayout.widget.ConstraintLayout>        </com.google.android.material.card.MaterialCardView>        <com.google.android.material.card.MaterialCardView           
    android:id="@+id/cardAbout"           
    android:layout_width="match_parent"           
    android:layout_height="wrap_content"           
    android:layout_marginHorizontal="20dp"           
    android:layout_marginTop="16dp"            app:cardCornerRadius="24dp"            app:cardElevation="0dp"            app:strokeWidth="1dp"            app:strokeColor="@color/line"            app:cardBackgroundColor="@color/white"            app:layout_constraintTop_toBottomOf="@id/cardResult">            <LinearLayout               
    android:layout_width="match_parent"               
    android:layout_height="wrap_content"               
    android:orientation="vertical"               
    android:padding="20dp">                <TextView                   
    android:layout_width="wrap_content"                   
    android:layout_height="wrap_content"                   
    android:text="About This Condition"                   
    android:textColor="@color/text_primary"                   
    android:textSize="18sp"                   
    android:textStyle="bold" />                <TextView                   
    android:id="@+id/tvDesc"                   
    android:layout_width="match_parent"                   
    android:layout_height="wrap_content"                   
    android:layout_marginTop="12dp"                   
    android:text="The eye appears healthy with no signs of inflammation or infection."                   
    android:textColor="@color/text_secondary"                   
    android:textSize="14sp"                   
    android:lineSpacingExtra="4dp" />                <com.google.android.material.button.MaterialButton                   
    android:id="@+id/tvFullDetails"                    style="@style/Widget.Material3.Button.TextButton"                   
    android:layout_width="wrap_content"                   
    android:layout_height="wrap_content"                   
    android:layout_marginTop="12dp"                   
    android:paddingStart="0dp"                   
    android:text="View Full Details  ›"                   
    android:textColor="@color/accent"                   
    android:textSize="14sp"                   
    android:textStyle="bold" />            </LinearLayout>        </com.google.android.material.card.MaterialCardView>        <LinearLayout           
            android:id="@+id/actionsRow"           
            android:layout_width="match_parent"           
            android:layout_height="wrap_content"           
            android:layout_marginTop="24dp"           
            android:orientation="horizontal"           
            android:paddingHorizontal="16dp"            app:layout_constraintTop_toBottomOf="@id/cardAbout">            
            
            <com.google.android.material.button.MaterialButton               
                android:id="@+id/btnSaveResult"                style="@style/Widget.Material3.Button.TonalButton"               
                android:layout_width="0dp"               
                android:layout_height="64dp"               
                android:layout_marginHorizontal="4dp"               
                android:layout_weight="1"               
                android:text="Save"               
                android:textAllCaps="false"               
                android:textStyle="bold"                app:cornerRadius="18dp"                app:icon="@android:drawable/ic_menu_save"                app:iconSize="20dp" />

            <com.google.android.material.button.MaterialButton               
                android:id="@+id/btnShareResult"                style="@style/Widget.Material3.Button.TonalButton"               
                android:layout_width="0dp"               
                android:layout_height="64dp"               
                android:layout_marginHorizontal="4dp"               
                android:layout_weight="1"               
                android:text="Share"               
                android:textAllCaps="false"               
                android:textStyle="bold"                app:cornerRadius="18dp"                app:icon="@android:drawable/ic_menu_share"                app:iconSize="20dp" />

            <com.google.android.material.button.MaterialButton               
                android:id="@+id/btnNewScan"               
                android:layout_width="0dp"               
                android:layout_height="64dp"               
                android:layout_marginHorizontal="4dp"               
                android:layout_weight="1.5"               
                android:text="New Scan"               
                android:textAllCaps="false"               
                android:textStyle="bold"                app:cornerRadius="18dp"                app:icon="@android:drawable/ic_menu_camera"                app:iconSize="20dp" />        
        </LinearLayout>        <com.google.android.material.card.MaterialCardView           
    android:id="@+id/academicDisclaimer"           
    android:layout_width="match_parent"           
    android:layout_height="wrap_content"           
    android:layout_marginHorizontal="20dp"           
    android:layout_marginTop="24dp"            app:cardCornerRadius="16dp"            app:cardElevation="0dp"            app:strokeWidth="1dp"            app:strokeColor="@color/line"            app:cardBackgroundColor="@color/accent_soft"            app:layout_constraintTop_toBottomOf="@id/actionsRow">            <LinearLayout               
    android:layout_width="match_parent"               
    android:layout_height="wrap_content"               
    android:padding="16dp"               
    android:orientation="horizontal"               
    android:gravity="top">                <ImageView                   
    android:layout_width="20dp"                   
    android:layout_height="20dp"                   
    android:layout_marginTop="2dp"                   
    android:src="@android:drawable/ic_dialog_info"                    app:tint="@color/accent" />                <TextView                   
    android:layout_width="match_parent"                   
    android:layout_height="wrap_content"                   
    android:layout_marginStart="12dp"                   
    android:text="Academic Disclaimer: This result is generated using AI for research demonstration intent only. It is not a medical diagnosis. Please consult a qualified doctor for clinical concerns."                   
    android:textColor="@color/accent"                   
    android:textSize="12sp"                   
    android:lineSpacingExtra="2dp" />            </LinearLayout>        </com.google.android.material.card.MaterialCardView>    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>